<div id="toast"></div>

<script>
// ═══════════════════════
// STATE
// ═══════════════════════
let totals=[0,0,0,0], history=[], currentRound=1, dealerIndex=0,
    activeIndex=0, winnerShown=false, loserShown=false,
    winLimit=500, loseLimit=null;

// رسائل سخرية عند الخسارة
const LOSER_MSGS = [
    "هاردلك يالأمير 👑\nواضح اللعب مو مجالك، جرب الطبخ؟",
    "ماشاء الله عليك 🎉\nوصلت للقاع بسرعة قياسية!",
    "لا تحزن 😅\nالخسارة تجربة.. وأنت خبرت كثير منها الليلة",
    "يالله يالله 🙈\nحتى الكمبيوتر تعاطف معك وهو يحسب نقاطك",
    "ربك ستر 😂\nبس ما ستر نقاطك للأسف",
    "طلعت أمير الخاسرين 👑\nلازم موهبة تخسر بهالشكل!",
    "مبروك على الإنجاز 🏅\nأول مرة في التاريخ يخسر بهالسرعة"
];

// ═══════════════════════
// INIT
// ═══════════════════════
function initApp() {
    const grid = document.getElementById('players-grid');
    let html = '';
    for (let i=0;i<4;i++) {
        html += `
        <div class="player-card" id="card${i}" onclick="setActive(${i})">
            <div class="name-wrapper">
                <input type="text" class="name-input" id="name${i}" value="لاعب ${i+1}"
                    maxlength="12" onchange="saveNames()" onclick="event.stopPropagation()">
                <button class="del-name" onclick="clearSingleName(${i},event)">×</button>
            </div>
            <div class="total-score" id="score${i}">0</div>
            <div class="score-display" id="input${i}"></div>
            <div class="near-win-badge" id="near${i}">🔥 قريب!</div>
        </div>`;
    }
    grid.innerHTML = html;
    loadState();
    loadTheme();
    loadKbSize();
    adjustBodyPadding();
    setActive(0);
}

function adjustBodyPadding() {
    const n = document.getElementById('numpad');
    if (n) document.body.style.paddingBottom = (n.offsetHeight + 20) + 'px';
}
window.addEventListener('resize', adjustBodyPadding);

// ═══════════════════════
// MENU
// ═══════════════════════
function toggleMenu() {
    const dd = document.getElementById('dropdown');
    const ov = document.getElementById('menu-overlay');
    dd.classList.toggle('open');
    ov.classList.toggle('open');
}
function closeMenu() {
    document.getElementById('dropdown').classList.remove('open');
    document.getElementById('menu-overlay').classList.remove('open');
}

// ═══════════════════════
// THEMES
// ═══════════════════════
const THEMES = ['dark','light','gold','green','ocean','rose'];
function setTheme(theme) {
    THEMES.forEach(t => document.body.classList.remove('theme-'+t));
    document.body.classList.add('theme-'+theme);
    localStorage.setItem('theme_v14', theme);
    document.querySelectorAll('.theme-chip').forEach((el,i) => {
        el.classList.toggle('active-theme', THEMES[i] === theme);
    });
    closeMenu();
}
function loadTheme() {
    const saved = localStorage.getItem('theme_v14') || 'dark';
    setTheme(saved);
}

// ═══════════════════════
// KEYBOARD SIZE
// ═══════════════════════
function setKbSize(size) {
    ['small','medium','large'].forEach(s => {
        document.body.classList.remove('kb-'+s);
        document.getElementById('kb-'+s).classList.remove('active-kb');
    });
    document.body.classList.add('kb-'+size);
    document.getElementById('kb-'+size).classList.add('active-kb');
    localStorage.setItem('kbSize_v14', size);
    setTimeout(adjustBodyPadding, 250);
}
function loadKbSize() {
    const saved = localStorage.getItem('kbSize_v14') || 'medium';
    setKbSize(saved);
}

// ═══════════════════════
// SETTINGS (حدود)
// ═══════════════════════
function saveSettings() {
    const wl = parseInt(document.getElementById('win-limit-input').value);
    const ll = document.getElementById('lose-limit-input').value;
    winLimit  = (wl && wl > 0) ? wl : 500;
    loseLimit = (ll && parseInt(ll) > 0) ? parseInt(ll) : null;
    document.getElementById('win-limit-input').value = winLimit;
    localStorage.setItem('settings_v14', JSON.stringify({winLimit, loseLimit}));
    updateUI();
    showToast('✅ تم حفظ الإعدادات');
}
function loadSettings() {
    try {
        const s = JSON.parse(localStorage.getItem('settings_v14'));
        if (s) {
            winLimit  = s.winLimit  || 500;
            loseLimit = s.loseLimit || null;
            document.getElementById('win-limit-input').value  = winLimit;
            document.getElementById('lose-limit-input').value = loseLimit || '';
        }
    } catch(e){}
}

// ═══════════════════════
// NAMES
// ═══════════════════════
function clearSingleName(idx, e) {
    e.stopPropagation();
    const el = document.getElementById('name'+idx);
    el.value = ''; el.focus();
}
function saveNames() {
    localStorage.setItem('names_v14', JSON.stringify([0,1,2,3].map(i=>document.getElementById('name'+i).value)));
}
function loadNames() {
    try {
        const n = JSON.parse(localStorage.getItem('names_v14'));
        if (Array.isArray(n)) n.forEach((v,i)=>{ const el=document.getElementById('name'+i); if(el&&v) el.value=v; });
    } catch(e){}
}

// ═══════════════════════
// STATE SAVE/LOAD
// ═══════════════════════
function saveState() {
    try { localStorage.setItem('gameState_v14', JSON.stringify({totals,currentRound,dealerIndex})); } catch(e){}
}
function loadState() {
    loadNames();
    loadSettings();
    try {
        const raw = localStorage.getItem('gameState_v14');
        if (raw) {
            const s = JSON.parse(raw);
            if (Array.isArray(s.totals) && s.totals.length===4) {
                totals=s.totals; currentRound=s.currentRound||1; dealerIndex=s.dealerIndex||0;
            }
        }
    } catch(e){}
    updateUI();
}

// ═══════════════════════
// ACTIVE
// ═══════════════════════
function setActive(idx) {
    activeIndex=idx;
    document.querySelectorAll('.score-display').forEach(el=>el.classList.remove('active-input'));
    document.querySelectorAll('.player-card').forEach(el=>el.classList.remove('active-card'));
    document.getElementById('input'+idx).classList.add('active-input');
    document.getElementById('card'+idx).classList.add('active-card');
}

// ═══════════════════════
// NUMPAD
// ═══════════════════════
function pressNum(val) {
    const display = document.getElementById('input'+activeIndex);
    const cur = display.innerText;
    if (val==='del') display.innerText = cur.slice(0,-1);
    else if (val==='-') { if (cur===''||cur==='0') display.innerText='-'; }
    else if (cur.length<5) display.innerText += val;
    validateInputs();
}

// ═══════════════════════
// VALIDATE
// ═══════════════════════
function validateInputs() {
    const vals = [0,1,2,3].map(i=>parseInt(document.getElementById('input'+i).innerText)||0);
    const sum = vals.reduce((a,b)=>a+b,0);
    const btn = document.getElementById('main-submit');
    const ok = sum===130;
    btn.innerText = ok ? '✅ المجموع: 130 — قيد الآن!' : `المجموع: ${sum} (المطلوب 130)`;
    btn.style.opacity   = ok?'1':'0.5';
    btn.style.background = ok?'var(--success)':'var(--border)';
    btn.style.color = ok?'#000':'white';
    return ok;
}

// ═══════════════════════
// ADD SCORES
// ═══════════════════════
function addScores() {
    if (!validateInputs()) { showToast('⚠️ المجموع يجب أن يكون 130'); return; }
    const scores = [0,1,2,3].map(i=>parseInt(document.getElementById('input'+i).innerText)||0);
    history.unshift({totals:[...totals], dealer:dealerIndex});
    scores.forEach((s,i)=>totals[i]+=s);
    dealerIndex=(dealerIndex+1)%4; currentRound++;
    [0,1,2,3].forEach(i=>document.getElementById('input'+i).innerText='');
    updateUI(); saveState(); setActive(0);
    if(navigator.vibrate) navigator.vibrate([60,30,60]);
    validateInputs();
}

// ═══════════════════════
// UPDATE UI
// ═══════════════════════
function updateUI() {
    document.getElementById('round-counter').innerText=`الجولة: ${currentRound}`;
    const nearThreshold = Math.round(winLimit * 0.1); // آخر 10%

    totals.forEach((s,i)=>{
        const sc    = document.getElementById('score'+i);
        const card  = document.getElementById('card'+i);
        const badge = document.getElementById('near'+i);
        sc.innerText = s;

        const isNearWin = loseLimit
            ? false
            : (s >= winLimit - nearThreshold && s < winLimit);

        // لون النقاط
        if (loseLimit && s >= loseLimit) {
            sc.className = 'total-score danger';
            card.style.borderColor = 'var(--danger)';
        } else if (s >= winLimit) {
            sc.className = 'total-score danger';
            card.style.borderColor = 'var(--danger)';
        } else if (isNearWin) {
            sc.className = 'total-score near-win';
            card.style.borderColor = '#ff9f1c';
        } else if (s >= winLimit * 0.8) {
            sc.className = 'total-score warn';
            card.style.borderColor = 'var(--warn)';
        } else {
            sc.className = 'total-score';
            card.style.borderColor = 'var(--border)';
        }

        // شارة الاقتراب
        badge.classList.toggle('show', isNearWin);

        card.classList.toggle('is-dealer', i===dealerIndex);

        // فوز
        if (s >= winLimit && !winnerShown) {
            winnerShown = true;
            const name = document.getElementById('name'+i).value || `لاعب ${i+1}`;
            setTimeout(()=>showWinner(name, s), 300);
        }

        // خسارة (اختياري)
        if (loseLimit && s >= loseLimit && !loserShown) {
            loserShown = true;
            const name = document.getElementById('name'+i).value || `لاعب ${i+1}`;
            setTimeout(()=>showLoser(name, s), 300);
        }
    });
}

// ═══════════════════════
// WINNER + CONFETTI
// ═══════════════════════
function showWinner(name, score) {
    document.getElementById('winner-name').innerText = `🎉 ${name}`;
    document.getElementById('winner-score').innerText = `وصل إلى ${score} نقطة!`;
    document.getElementById('winner-overlay').style.display = 'flex';
    if(navigator.vibrate) navigator.vibrate([200,100,200,100,300]);
    startConfetti();
}
function closeWinner() {
    document.getElementById('winner-overlay').style.display='none';
    stopConfetti();
}

// ═══════════════════════
// LOSER
// ═══════════════════════
function showLoser(name, score) {
    document.getElementById('loser-name').innerText = name;
    const msg = LOSER_MSGS[Math.floor(Math.random() * LOSER_MSGS.length)];
    document.getElementById('loser-msg').innerText = `وصل إلى ${score} نقطة!\n\n${msg}`;
    document.getElementById('loser-overlay').style.display='flex';
    if(navigator.vibrate) navigator.vibrate([300,100,300]);
}
function closeLoser() { document.getElementById('loser-overlay').style.display='none'; }

// ═══════════════════════
// CONFETTI
// ═══════════════════════
let confettiAnimId = null;
function startConfetti() {
    const canvas = document.getElementById('confetti-canvas');
    canvas.style.display = 'block';
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
    const ctx = canvas.getContext('2d');
    const pieces = Array.from({length:150}, ()=>({
        x: Math.random()*canvas.width,
        y: Math.random()*canvas.height - canvas.height,
        w: Math.random()*10+5, h: Math.random()*6+4,
        color: `hsl(${Math.random()*360},90%,60%)`,
        vx: Math.random()*3-1.5,
        vy: Math.random()*4+2,
        rot: Math.random()*360,
        rspeed: Math.random()*5-2.5
    }));
    function draw() {
        ctx.clearRect(0,0,canvas.width,canvas.height);
        pieces.forEach(p=>{
            ctx.save(); ctx.translate(p.x,p.y); ctx.rotate(p.rot*Math.PI/180);
            ctx.fillStyle=p.color; ctx.fillRect(-p.w/2,-p.h/2,p.w,p.h);
            ctx.restore();
            p.x+=p.vx; p.y+=p.vy; p.rot+=p.rspeed;
            if(p.y>canvas.height) { p.y=-10; p.x=Math.random()*canvas.width; }
        });
        confettiAnimId = requestAnimationFrame(draw);
    }
    draw();
    setTimeout(stopConfetti, 5000);
}
function stopConfetti() {
    if(confettiAnimId) { cancelAnimationFrame(confettiAnimId); confettiAnimId=null; }
    const canvas = document.getElementById('confetti-canvas');
    canvas.style.display='none';
    canvas.getContext('2d').clearRect(0,0,canvas.width,canvas.height);
}

// ═══════════════════════
// UNDO
// ═══════════════════════
function undo() {
    if (!history.length) { showToast('⚠️ لا يوجد قيد للتراجع'); return; }
    const last=history.shift();
    totals=[...last.totals]; dealerIndex=last.dealer; currentRound--;
    winnerShown = totals.some(s=>s>=winLimit);
    loserShown  = loseLimit ? totals.some(s=>s>=loseLimit) : false;
    updateUI(); saveState(); showToast('↩️ تم التراجع عن آخر قيد');
}

// ═══════════════════════
// DEALER
// ═══════════════════════
function moveDealer() { dealerIndex=(dealerIndex+1)%4; updateUI(); }

// ═══════════════════════
// RESET
// ═══════════════════════
function confirmReset() {
    if (!confirm('هل تريد تصفير النشرة بالكامل؟')) return;
    totals=[0,0,0,0]; history=[]; currentRound=1; dealerIndex=0;
    activeIndex=0; winnerShown=false; loserShown=false;
    [0,1,2,3].forEach(i=>document.getElementById('input'+i).innerText='');
    localStorage.removeItem('gameState_v14');
    stopConfetti(); updateUI(); validateInputs(); setActive(0);
    showToast('🔄 تم تصفير النشرة');
}

// ═══════════════════════
// QR & SHARE
// ═══════════════════════
function buildResultsText() {
    let text = `🃏 نشرة أبو سلاس\nالجولة: ${currentRound-1}\n${'─'.repeat(20)}\n`;
    [0,1,2,3].forEach(i=>{
        const name=document.getElementById('name'+i).value||`لاعب ${i+1}`;
        text += `${name}: ${totals[i]} نقطة\n`;
    });
    text += `${'─'.repeat(20)}\nتطوير: أبو سلاس © 2026`;
    return text;
}

function openQR() {
    const modal = document.getElementById('qr-modal');
    const qrContainer = document.getElementById('qrcode');
    const scoresEl = document.getElementById('qr-scores-text');
    qrContainer.innerHTML = '';

    const text = buildResultsText();
    let html = '';
    [0,1,2,3].forEach(i=>{
        const name=document.getElementById('name'+i).value||`لاعب ${i+1}`;
        html+=`<div style="display:flex;justify-content:space-between;padding:2px 0">
            <span style="color:var(--primary);font-weight:700">${totals[i]}</span>
            <span>${name}</span>
        </div>`;
    });
    html+=`<div style="color:var(--text-sub);font-size:0.78rem;margin-top:6px;text-align:center">الجولة ${currentRound-1}</div>`;
    scoresEl.innerHTML = html;

    try {
        new QRCode(qrContainer, {
            text: text.substring(0, 200),
            width:180, height:180,
            correctLevel: QRCode.CorrectLevel.M
        });
    } catch(e) {
        qrContainer.innerHTML = '<p style="color:var(--text-sub);font-size:0.8rem;padding:20px">تعذّر إنشاء الباركود</p>';
    }
    modal.style.display = 'flex';
}
function closeQR() { document.getElementById('qr-modal').style.display='none'; }

async function shareResults() {
    const text = buildResultsText();
    if (navigator.share) {
        try {
            await navigator.share({ title:'نشرة أبو سلاس', text });
            showToast('✅ تمت المشاركة');
        } catch(e) {
            if(e.name!=='AbortError') copyResults();
        }
    } else { copyResults(); }
}

function copyResults() {
    const text = buildResultsText();
    if (navigator.clipboard) {
        navigator.clipboard.writeText(text)
            .then(()=>showToast('📋 تم النسخ!'))
            .catch(()=>fallbackCopy(text));
    } else { fallbackCopy(text); }
    closeQR();
}
function fallbackCopy(text) {
    const ta=document.createElement('textarea');
    ta.value=text; document.body.appendChild(ta);
    ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
    showToast('📋 تم النسخ!');
}

// ═══════════════════════
// TOAST
// ═══════════════════════
function showToast(msg) {
    const t=document.getElementById('toast');
    t.innerText=msg; t.classList.add('show');
    setTimeout(()=>t.classList.remove('show'), 2500);
}
</script>

