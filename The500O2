    /* numpad sizes */
    body.kb-small  { --numpad-pad:10px; --numpad-font:1.15rem; }
    body.kb-medium { --numpad-pad:18px; --numpad-font:1.5rem; }
    body.kb-large  { --numpad-pad:26px; --numpad-font:1.85rem; }

    * { box-sizing:border-box; margin:0; padding:0; -webkit-tap-highlight-color:transparent; }

    body {
        font-family:'Cairo','Segoe UI',Tahoma,sans-serif;
        background:var(--bg-body); color:var(--text-main);
        text-align:center; padding:10px;
        padding-bottom:300px;
        transition:background 0.35s,color 0.35s;
        user-select:none; overflow-x:hidden; min-height:100vh;
    }

    /* ══ TOP BAR ══ */
    .top-bar {
        display:flex; justify-content:space-between;
        max-width:500px; margin:0 auto 12px; gap:8px; align-items:center;
    }
    .icon-btn {
        background:var(--bg-card); border:1px solid var(--border);
        color:var(--text-main); padding:10px 8px; border-radius:12px;
        flex:1; cursor:pointer; font-family:'Cairo',sans-serif;
        font-size:0.82rem; font-weight:700;
        transition:background 0.2s,transform 0.1s;
    }
    .icon-btn:active { transform:scale(0.95); }
    .menu-btn {
        background:var(--bg-card); border:1px solid var(--border);
        color:var(--text-main); width:44px; height:44px;
        border-radius:12px; cursor:pointer; font-size:1.3rem;
        display:flex; align-items:center; justify-content:center;
        flex-shrink:0; transition:background 0.2s,transform 0.1s;
    }
    .menu-btn:active { transform:scale(0.93); }

    /* ══ DROPDOWN — fixed overlay, لا يزعزع الصفحة ══ */
    .menu-wrapper { position:relative; }
    .dropdown {
        display:none;
        position:fixed;
        top:0; right:0; bottom:0;
        width:260px;
        background:var(--bg-card);
        border-left:1px solid var(--border);
        z-index:2000;
        overflow-y:auto;
        box-shadow:-8px 0 32px rgba(0,0,0,0.5);
        animation:slideInRight 0.22s ease;
    }
    @keyframes slideInRight {
        from { transform:translateX(100%); opacity:0; }
        to   { transform:translateX(0);    opacity:1; }
    }
    .dropdown.open { display:block; }
    .menu-section-title {
        padding:14px 16px 8px;
        font-size:0.75rem; font-weight:700;
        color:var(--text-sub); text-align:right;
        border-bottom:1px solid var(--border);
        letter-spacing:0.5px; position:sticky; top:0;
        background:var(--bg-card); z-index:1;
    }
    .menu-close-row {
        display:flex; align-items:center; justify-content:space-between;
        padding:14px 16px;
        border-bottom:1px solid var(--border);
    }
    .menu-close-row span { font-weight:900; font-size:1rem; color:var(--primary); }
    .menu-close-x {
        background:var(--border); border:none; border-radius:8px;
        color:var(--text-main); width:32px; height:32px;
        cursor:pointer; font-size:1rem; font-family:'Cairo',sans-serif;
        display:flex; align-items:center; justify-content:center;
    }
    .themes-grid {
        display:grid; grid-template-columns:repeat(3,1fr);
        gap:8px; padding:12px;
    }
    .theme-chip {
        border-radius:10px; padding:8px 4px;
        cursor:pointer; font-size:0.75rem; font-weight:700;
        border:2px solid transparent;
        transition:transform 0.15s, border-color 0.2s;
        font-family:'Cairo',sans-serif;
    }
    .theme-chip:active { transform:scale(0.93); }
    .theme-chip.active-theme { border-color:white !important; }

    /* كيبورد سايز */
    .kb-size-row {
        display:flex; gap:6px; padding:10px 12px;
    }
    .kb-size-btn {
        flex:1; padding:8px 4px; border-radius:8px;
        background:var(--numpad-btn); border:2px solid transparent;
        color:var(--text-main); font-family:'Cairo',sans-serif;
        font-size:0.78rem; font-weight:700; cursor:pointer;
        transition:border-color 0.2s,transform 0.1s;
    }
    .kb-size-btn:active { transform:scale(0.93); }
    .kb-size-btn.active-kb { border-color:var(--primary); color:var(--primary); }

    /* حد الفوز / الخسارة */
    .limit-row {
        display:flex; align-items:center; justify-content:space-between;
        padding:12px 16px; border-bottom:1px solid var(--border);
        gap:8px;
    }
    .limit-label { font-size:0.88rem; font-weight:700; color:var(--text-main); }
    .limit-input {
        background:var(--input-bg); border:1px solid var(--border);
        color:var(--accent); border-radius:8px; padding:6px 10px;
        width:80px; text-align:center;
        font-family:'Cairo',sans-serif; font-size:0.95rem; font-weight:700;
    }
    .limit-input:focus { outline:none; border-color:var(--primary); }

    .menu-item {
        display:flex; align-items:center; gap:10px;
        padding:13px 16px; cursor:pointer;
        font-size:0.9rem; font-weight:700;
        transition:background 0.15s;
        border-bottom:1px solid var(--border);
        text-align:right;
    }
    .menu-item:active { background:var(--border); }
    .menu-item .mi-icon { font-size:1.1rem; width:22px; text-align:center; flex-shrink:0; }

    /* ══ HEADER ══ */
    .header-top {
        max-width:500px; margin:0 auto 14px;
        display:flex; justify-content:space-between; align-items:center;
    }
    h2 { color:var(--primary); font-size:1.4rem; font-weight:900; }
    #round-counter {
        background:var(--bg-card); padding:5px 14px;
        border-radius:20px; border:1px solid var(--border);
        font-size:0.85rem; font-weight:700; color:var(--text-sub);
    }

    /* ══ PLAYER CARDS ══ */
    .players-container {
        display:grid; grid-template-columns:repeat(2,1fr);
        gap:10px; max-width:500px; margin:0 auto;
    }
    .player-card {
        background:var(--bg-card); padding:14px 8px 12px;
        border-radius:18px; border:2px solid var(--border);
        position:relative; cursor:pointer;
        transition:border-color 0.25s,box-shadow 0.25s,transform 0.15s;
    }
    .player-card:active { transform:scale(0.97); }
    .player-card.active-card {
        border-color:var(--primary);
        box-shadow:0 0 16px var(--card-glow);
    }
    .name-wrapper {
        display:flex; align-items:center; justify-content:center;
        gap:4px; margin-bottom:6px; padding:0 4px;
    }
    .name-input {
        background:transparent; border:none;
        border-bottom:1px solid var(--border);
        color:var(--primary); text-align:center;
        font-weight:700; font-family:'Cairo',sans-serif;
        width:0; flex:1; font-size:0.95rem; max-width:110px;
        overflow:hidden; text-overflow:ellipsis; white-space:nowrap;
        font-size:16px; /* منع zoom على iOS */
    }
    .name-input:focus { outline:none; border-bottom-color:var(--primary); }
    .del-name {
        background:rgba(239,71,111,0.15); color:var(--danger);
        border:none; border-radius:50%; width:22px; height:22px;
        cursor:pointer; font-size:13px;
        display:flex; align-items:center; justify-content:center;
        flex-shrink:0; transition:background 0.2s;
    }
    .del-name:active { background:rgba(239,71,111,0.35); }
    .total-score {
        font-size:2.6em; color:var(--accent);
        font-weight:900; margin:4px 0; line-height:1.1;
        transition:color 0.3s;
    }
    .total-score.danger { color:var(--danger); animation:pulse 1s infinite; }
    .total-score.warn   { color:var(--warn); }
    .total-score.near-win { color:#ff9f1c; animation:nearPulse 0.8s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.6} }
    @keyframes nearPulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.05)} }

    .score-display {
        width:85%; padding:8px 10px; border-radius:10px;
        background:var(--input-bg); color:var(--text-main);
        font-size:1.5rem; font-weight:700;
        font-family:'Cairo',sans-serif; min-height:42px;
        border:2px solid transparent; margin:0 auto;
        transition:border-color 0.2s,box-shadow 0.2s;
    }
    .active-input {
        border-color:var(--primary) !important;
        box-shadow:0 0 10px var(--card-glow);
    }
    .is-dealer::after {
        content:"🃏 الموزع";
        position:absolute; top:-11px; left:50%; transform:translateX(-50%);
        background:var(--danger); color:white;
        padding:2px 12px; border-radius:20px;
        font-size:0.68rem; font-weight:700; white-space:nowrap;
    }
    /* شارة الاقتراب */
    .near-win-badge {
        position:absolute; bottom:-10px; left:50%; transform:translateX(-50%);
        background:#ff9f1c; color:#000;
        padding:2px 10px; border-radius:20px;
        font-size:0.65rem; font-weight:700; white-space:nowrap;
        display:none;
    }
    .near-win-badge.show { display:block; }

    /* ══ SUBMIT ══ */
    #main-submit {
        background:var(--border); color:white; padding:16px;
        border:none; border-radius:14px; width:95%; max-width:500px;
        margin-top:14px; font-weight:700; font-size:1.05rem;
        font-family:'Cairo',sans-serif;
        transition:background 0.25s,opacity 0.25s,transform 0.1s;
        opacity:0.5; cursor:pointer;
    }
    #main-submit:active { transform:scale(0.98); }

    /* ══ ACTION ROW ══ */
    .action-row {
        display:flex; gap:10px; max-width:500px;
        margin:12px auto; width:95%;
    }
    .action-row button {
        flex:1; padding:14px; border-radius:12px;
        border:none; font-weight:700;
        font-family:'Cairo',sans-serif; font-size:0.95rem;
        cursor:pointer; transition:opacity 0.2s,transform 0.1s;
    }
    .action-row button:active { transform:scale(0.97); opacity:0.85; }

    /* ══ NUMPAD ══ */
    .numpad {
        position:fixed; bottom:0; left:0; width:100%;
        background:var(--numpad-bg);
        padding:10px 10px 14px;
        display:grid; grid-template-columns:repeat(4,1fr);
        gap:6px; z-index:1000;
        border-top:1px solid var(--border);
        border-radius:20px 20px 0 0;
        box-shadow:0 -4px 20px rgba(0,0,0,0.4);
        transition:padding 0.2s;
    }
    .num-btn {
        background:var(--numpad-btn); color:var(--text-main);
        border:1px solid var(--border);
        padding:var(--numpad-pad) 0;
        font-size:var(--numpad-font); font-weight:700;
        font-family:'Cairo',sans-serif;
        border-radius:12px; cursor:pointer;
        touch-action:manipulation;
        transition:background 0.15s,transform 0.1s,padding 0.2s,font-size 0.2s;
    }
    .num-btn:active { background:var(--border); transform:scale(0.93); }

    /* ══ FOOTER ══ */
    .footer-credits {
        margin:20px auto; padding:16px;
        color:var(--text-sub); font-size:0.85rem;
        border-top:1px solid var(--border); max-width:500px;
    }

    /* ══ QR MODAL ══ */
    #qr-modal {
        display:none; position:fixed; inset:0;
        background:rgba(0,0,0,0.92); z-index:3000;
        justify-content:center; align-items:center; flex-direction:column;
        padding:20px;
    }
    .qr-box {
        background:var(--bg-card); border:1px solid var(--border);
        border-radius:24px; padding:28px 24px;
        max-width:320px; width:100%;
        animation:popIn 0.3s ease;
    }
    .qr-title { color:var(--primary); font-size:1.1rem; font-weight:900; margin-bottom:6px; }
    .qr-subtitle { color:var(--text-sub); font-size:0.8rem; margin-bottom:16px; }
    #qrcode {
        background:white; padding:12px;
        border-radius:14px; display:inline-block; margin-bottom:16px;
    }
    .qr-scores {
        background:var(--input-bg); border-radius:12px;
        padding:12px; margin-bottom:16px;
        text-align:right; font-size:0.9rem;
        color:var(--text-main); line-height:2;
    }
    .qr-actions { display:grid; grid-template-columns:1fr 1fr; gap:8px; }
    .qr-btn {
        padding:12px; border-radius:12px; border:none;
        font-family:'Cairo',sans-serif; font-weight:700;
        font-size:0.9rem; cursor:pointer; transition:transform 0.1s;
    }
    .qr-btn:active { transform:scale(0.96); }
    .qr-close {
        grid-column:span 2; padding:12px;
        border-radius:12px; border:none;
        background:var(--border); color:var(--text-main);
        font-family:'Cairo',sans-serif; font-weight:700;
        font-size:0.9rem; cursor:pointer; margin-top:4px;
    }

    /* ══ WINNER OVERLAY ══ */
    #winner-overlay {
        display:none; position:fixed; inset:0;
        background:rgba(0,0,0,0.88); z-index:4000;
        justify-content:center; align-items:center; flex-direction:column;
    }
    .winner-box {
        background:var(--bg-card); border:2px solid var(--accent);
        border-radius:24px; padding:40px 30px; text-align:center;
        animation:popIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
        max-width:320px; width:90%;
    }
    .winner-box h1 { font-size:3rem; margin-bottom:10px; }
    .winner-box h2 { color:var(--accent); font-size:1.8rem; margin-bottom:8px; }
    .winner-box p  { color:var(--text-sub); margin-bottom:25px; }
    .winner-close-btn {
        background:var(--success); color:#000;
        border:none; border-radius:12px; padding:14px 40px;
        font-size:1.1rem; font-weight:700;
        font-family:'Cairo',sans-serif; cursor:pointer;
    }

    /* ══ LOSER OVERLAY ══ */
    #loser-overlay {
        display:none; position:fixed; inset:0;
        background:rgba(0,0,0,0.9); z-index:4000;
        justify-content:center; align-items:center; flex-direction:column;
    }
    .loser-box {
        background:var(--bg-card); border:2px solid var(--danger);
        border-radius:24px; padding:36px 28px; text-align:center;
        animation:popIn 0.4s cubic-bezier(0.175,0.885,0.32,1.275);
        max-width:320px; width:90%;
    }
    .loser-emoji { font-size:3.5rem; margin-bottom:8px; }
    .loser-name { color:var(--danger); font-size:1.6rem; font-weight:900; margin-bottom:10px; }
    .loser-msg {
        color:var(--text-sub); font-size:1rem;
        line-height:1.7; margin-bottom:20px;
    }
    .loser-close-btn {
        background:var(--danger); color:white;
        border:none; border-radius:12px; padding:13px 36px;
        font-size:1rem; font-weight:700;
        font-family:'Cairo',sans-serif; cursor:pointer;
    }

    @keyframes popIn {
        from { transform:scale(0.5); opacity:0; }
        to   { transform:scale(1); opacity:1; }
    }

    /* ══ TOAST ══ */
    #toast {
        position:fixed; top:20px; left:50%;
        transform:translateX(-50%) translateY(-80px);
        background:var(--bg-card); border:1px solid var(--border);
        color:var(--text-main); padding:10px 24px;
        border-radius:30px; font-family:'Cairo',sans-serif;
        font-weight:700; font-size:0.95rem; z-index:5000;
        transition:transform 0.35s cubic-bezier(0.175,0.885,0.32,1.275);
        pointer-events:none; box-shadow:0 4px 24px rgba(0,0,0,0.4);
    }
    #toast.show { transform:translateX(-50%) translateY(0); }

    /* ══ CONFETTI ══ */
    #confetti-canvas {
        position:fixed; inset:0; z-index:3999;
        pointer-events:none; display:none;
    }

    /* overlay لإغلاق القائمة */
    #menu-overlay {
        display:none; position:fixed; inset:0; z-index:1999;
        background:rgba(0,0,0,0.45);
    }
    #menu-overlay.open { display:block; }
</style>
